LONGCAT_API_KEY=replace-with-your-key
LONGCAT_BASE_URL=https://your-openai-compatible-endpoint/v1
LONGCAT_MODEL=replace-with-your-model

# Optional shared secret used by the Java backend.
AGENT_SERVICE_TOKEN=

# Spring Boot internal API used for memories, exams, tasks and knowledge.
AGENT_BACKEND_BASE_URL=http://127.0.0.1:8080
AGENT_BACKEND_TIMEOUT_SECONDS=10

# Optional runtime tuning.
AGENT_DATABASE_PATH=data/agent_memory.db
AGENT_CONTEXT_MESSAGES=16
AGENT_REQUEST_TIMEOUT_SECONDS=60
AGENT_MAX_RETRIES=2
